#!/bin/bash
#SBATCH --job-name=bigmul-bench
#SBATCH --partition=grace
#SBATCH --gres=gpu:1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --time=02:00:00
#SBATCH --output=results/%j/slurm.out
#SBATCH --error=results/%j/slurm.err

set -euo pipefail

SIF="${SIF:-${HOME}/.singularity/bigmul.sif}"
MAX_N="${MAX_N:-65536}"
ITERS="${ITERS:-3}"
RESULTS_DIR="results/${SLURM_JOB_ID}"

mkdir -p "${RESULTS_DIR}"

nvidia-smi | tee "${RESULTS_DIR}/gpu-info.txt"

BENCH="singularity exec --nv ${SIF} ./build/bin/bench"

${BENCH} --max-n "${MAX_N}" --iters "${ITERS}"

nsys profile -o "${RESULTS_DIR}/nsys" \
    ${BENCH} --max-n "${MAX_N}" --iters 1

ncu --set full -o "${RESULTS_DIR}/ncu" \
    ${BENCH} --max-n 4096 --iters 1

echo "results saved to ${RESULTS_DIR}/"
