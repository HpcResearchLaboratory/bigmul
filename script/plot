#!/usr/bin/env python3
import sys
import matplotlib.pyplot as plt
import matplotlib.ticker as ticker
from openpyxl import load_workbook
from collections import defaultdict

XLSX = sys.argv[1] if len(sys.argv) > 1 else "result/report.xlsx"
OUT = "result"

COLORS = ["#2a78d6", "#1baf7a", "#eda100", "#4a3aa7"]
KERNEL_COLORS = {
    "butterfly": COLORS[0],
    "bit_reverse_permute": COLORS[1],
    "pointwise_mul": COLORS[2],
    "scale_mod": COLORS[3],
}

plt.rcParams.update({
    "figure.facecolor": "#fcfcfb",
    "axes.facecolor": "#fcfcfb",
    "axes.edgecolor": "#d0cfca",
    "axes.labelcolor": "#0b0b0b",
    "text.color": "#0b0b0b",
    "xtick.color": "#52514e",
    "ytick.color": "#52514e",
    "grid.color": "#e8e7e3",
    "grid.linewidth": 0.6,
    "font.size": 11,
    "axes.titlesize": 13,
    "axes.titleweight": "bold",
    "figure.dpi": 300,
    "savefig.dpi": 300,
})

wb = load_workbook(XLSX, read_only=True)


# --- 1. Wall-clock vs input size ---
if "Timings" in wb.sheetnames:
    ws = wb["Timings"]
    rows = list(ws.iter_rows(min_row=2, values_only=True))
    ns = [r[0] for r in rows]

    BATCH = 10
    mean = [r[1] / BATCH for r in rows]
    std = [r[2] / BATCH for r in rows]

    fig, ax = plt.subplots(figsize=(7, 4))
    ax.errorbar(ns, mean, yerr=std, color=COLORS[0], linewidth=2, marker="o",
                markersize=6, capsize=4, capthick=1.5)
    ax.set_xscale("log", base=2)
    ax.xaxis.set_major_formatter(ticker.FuncFormatter(lambda x, _: f"{int(x)}"))
    ax.set_xlabel("n (limbs)")
    ax.set_ylabel("per-multiply (ms)")
    ax.set_title("Multiply time vs input size")
    ax.grid(True, axis="y")
    fig.tight_layout()
    fig.savefig(f"{OUT}/timings.png")
    plt.close()
    print(f"  {OUT}/timings.png")


# --- 2. Kernel time breakdown ---
ws = wb["Kernels"]
rows = list(ws.iter_rows(min_row=2, values_only=True))

kernel_totals = defaultdict(float)
for name, dur, *_ in rows:
    kernel_totals[name] += dur / 1e6  # ns → ms

kernels = sorted(kernel_totals.keys(), key=lambda k: -kernel_totals[k])
totals = [kernel_totals[k] for k in kernels]

fig, ax = plt.subplots(figsize=(7, 4))
bars = ax.barh(kernels[::-1], totals[::-1], height=0.5,
               color=[KERNEL_COLORS.get(k, "#999") for k in kernels[::-1]])
ax.set_xlabel("total time (ms)")
ax.set_title("GPU kernel time breakdown")
for bar, val in zip(bars, totals[::-1]):
    ax.text(bar.get_width() + max(totals) * 0.02, bar.get_y() + bar.get_height() / 2,
            f"{val:.3f}", va="center", fontsize=9, color="#52514e")
ax.grid(True, axis="x")
fig.tight_layout()
fig.savefig(f"{OUT}/kernels.png")
plt.close()
print(f"  {OUT}/kernels.png")


# --- 3. Butterfly kernel profile ---
ws = wb["NCU Metrics"]
header = [c.value for c in next(ws.iter_rows(min_row=1, max_row=1))]
butterfly_rows = [dict(zip(header, r)) for r in ws.iter_rows(min_row=2, values_only=True)
                  if r[0] == "butterfly"]

if butterfly_rows:
    metrics = ["compute_pct", "memory_pct", "l1_hit_pct", "l2_hit_pct", "alu_pipe_pct"]
    labels = ["Compute\nthroughput", "Memory\nthroughput", "L1 hit rate", "L2 hit rate", "ALU pipe"]

    avgs = []
    for m in metrics:
        vals = [float(r[m]) for r in butterfly_rows if r.get(m)]
        avgs.append(sum(vals) / len(vals) if vals else 0)

    fig, ax = plt.subplots(figsize=(7, 4))
    bars = ax.bar(labels, avgs, width=0.5, color=COLORS[0])
    ax.set_ylabel("% of peak")
    ax.set_title("Butterfly kernel profile (avg across invocations)")
    ax.set_ylim(0, 100)
    for bar, val in zip(bars, avgs):
        ax.text(bar.get_x() + bar.get_width() / 2, bar.get_height() + 2,
                f"{val:.1f}%", ha="center", fontsize=9, color="#52514e")
    ax.grid(True, axis="y")
    fig.tight_layout()
    fig.savefig(f"{OUT}/butterfly_profile.png")
    plt.close()
    print(f"  {OUT}/butterfly_profile.png")

    # --- 4. Top stall reasons ---
    stall_totals = defaultdict(float)
    count = 0
    for r in butterfly_rows:
        for i in range(1, 4):
            sname = r.get(f"stall_{i}")
            sratio = r.get(f"stall_{i}_ratio")
            if sname and sratio:
                stall_totals[sname] += float(sratio)
        count += 1

    stalls = sorted(stall_totals.items(), key=lambda x: -x[1])[:5]
    snames = [s[0] for s in stalls]
    svals = [s[1] / count for s in stalls]

    fig, ax = plt.subplots(figsize=(7, 4))
    ax.barh(snames[::-1], svals[::-1], height=0.5, color=COLORS[3])
    ax.set_xlabel("avg stall ratio")
    ax.set_title("Butterfly kernel — top warp stall reasons")
    ax.grid(True, axis="x")
    fig.tight_layout()
    fig.savefig(f"{OUT}/stalls.png")
    plt.close()
    print(f"  {OUT}/stalls.png")

wb.close()
