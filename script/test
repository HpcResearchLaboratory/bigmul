#!/bin/bash
set -euo pipefail
export LC_ALL=C LANG=C

BIN="${1:-./build/bin/multiply}"

check() { echo "$1 $2 $("${BIN}" "$1" "$2")"; }

check 0 0
check 1 1
check 7 6
check FF 2
check FFFFFFFF FFFFFFFF
check FFFFFFFFFFFFFFFF FFFFFFFFFFFFFFFF
check 1FFFFFFFF 2
check FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
check 100000000 10000000000000000
check 1 100000000000000000000000000000000
check DEADBEEFCAFEBABE 123456789ABCDEF0
check FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF \
      FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
check 1 FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
check ABCDEF 1

for bits in 64 128 256 512 1024; do
    a=$(openssl rand -hex $((bits / 8)) | tr '[:lower:]' '[:upper:]')
    b=$(openssl rand -hex $((bits / 8)) | tr '[:lower:]' '[:upper:]')
    check "$a" "$b"
done | perl -MMath::BigInt -lane '
    my ($a, $b, $got) = @F;
    my $exp = uc substr(Math::BigInt->from_hex($a)->bmul(Math::BigInt->from_hex($b))->as_hex, 2);
    if (uc $got eq $exp) { $p++ } else { $f++; print "FAIL: $a * $b\n  exp: $exp\n  got: $got" }
    END { $p//=0; $f//=0; print "$p passed, $f failed"; exit($f?1:0) }
'
