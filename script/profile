#!/bin/bash
set -euo pipefail

MAX_N=65536
while [[ $# -gt 0 ]]; do
    case "$1" in --max-n)
        MAX_N="$2"
        shift 2
        ;;
    *)
        echo "unknown: $1"
        exit 1
        ;;
    esac
done

CLUSTER="pcad"
REMOTE="\${HOME}/bigmul"

rsync -az --exclude='build/' --exclude='.cache/' --exclude='config.mk' --exclude='results/' --exclude='data/' \
    ./ "${CLUSTER}:bigmul/"

ssh "${CLUSTER}" "srun -p grace --gres=gpu:1 --cpus-per-task=4 --mem=16G --time=01:00:00 \
    bash -c 'cd ${REMOTE} && script/bench ${MAX_N}'"

mkdir -p data
rsync -az "${CLUSTER}:bigmul/data/" data/
